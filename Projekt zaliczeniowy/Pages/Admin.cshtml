@page
@model Projekt_zaliczeniowy.Pages.AdminModel
@{
    ViewData["Title"] = "Panel Administratora";
}

<div class="container my-5" style="max-width: 700px;">
    <h2 class="mb-4">Dodaj konto ucznia</h2>

    @if (!string.IsNullOrEmpty(Model.komunikat))
    {
        <div class="alert alert-info">@Model.komunikat</div>
    }

    <form method="post" class="mb-5">
        <div class="mb-3">
            <label class="form-label">Login ucznia</label>
            <input type="text" asp-for="nowy_login" class="form-control" required autocomplete="off" />
        </div>
        <div class="mb-3">
            <label class="form-label">Hasło</label>
            <input type="text" asp-for="nowe_haslo" class="form-control" required autocomplete="off" />
        </div>
        <button type="submit" class="btn btn-primary">Dodaj konto</button>
    </form>

    <h4>Lista uczniów</h4>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Login</th>
                <th>Liczba prób</th>
                <th>Poprawne</th>
                <th>Skuteczność</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var uczen in Model.Uczniowie)
            {
                int proby = uczen.Wynik?.liczba_prob ?? 0;
                int poprawne = uczen.Wynik?.liczba_poprawnych ?? 0;
                string skutecznosc = proby > 0 ? $"{(poprawne * 100 / proby)}%" : "brak danych";

                <tr>
                    <td>@uczen.Login</td>
                    <td>@proby</td>
                    <td>@poprawne</td>
                    <td>@skutecznosc</td>
                </tr>
            }
        </tbody>
    </table>
</div>
<h4 class="mt-5">Najczęstsze błędy uczniów</h4>
@if (!Model.statystyki.Any())
{
    <p class="text-muted">Brak jeszcze zebranych danych.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Typ zadania</th>
                <th>Liczba błędnych odpowiedzi</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var pozycja in Model.statystyki)
            {
                <tr>
                    <td>@Model.NazwaZadania(pozycja.typ_zadania)</td>
                    <td>@pozycja.liczba_bledow</td>
                </tr>
            }
        </tbody>
    </table>
}
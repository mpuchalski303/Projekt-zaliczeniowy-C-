@page
@model Projekt_zaliczeniowy.Pages.LogowanieModel
@{
    ViewData["Title"] = "Logowanie";
}

<div class="container my-5">
    <div class="row">
        <div class="col-md-4 mx-auto">
            <div class="card shadow-lg border-0 rounded-4 mt-5">
                <div class="card-body p-5">
                    <h2 class="fw-bold text-center text-primary mb-4">Logowanie</h2>
                    

                    @if (!string.IsNullOrEmpty(Model.blad_logowania))
                    {
                        <div class="alert alert-danger text-center small rounded-3 py-2" role="alert">
                            @Model.blad_logowania
                        </div>
                    }

                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">Login</label>
                            <input type="text" asp-for="Login" class="form-control border-2" required autocomplete="off" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-muted small fw-bold">Hasło</label>
                            <input type="password" asp-for="Haslo" class="form-control border-2" required />
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg rounded-3 fw-bold shadow-sm py-2" style="font-size: 1.1rem;">Zaloguj się</button>
                        </div>
                    </form>
                    
                    
                </div>
            </div>
        </div>
    </div>
</div>
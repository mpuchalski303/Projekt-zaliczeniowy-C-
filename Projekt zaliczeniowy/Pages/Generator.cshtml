@page
@model Projekt_zaliczeniowy.Pages.GeneratorModel
@{
    ViewData["Title"] = "Generator Zadań";
}
<div class="container my-5">
    <div class="row mb-4 text-center">
        <div class="col-md-8 mx-auto">
            <h1 class="display-5 fw-bold text-primary">Generator Zadań Rachunkowy</h1>

            <div class="d-inline-flex align-items-baseline gap-2 mt-3 mb-2">
                <span class="text-uppercase text-muted" style="font-size: 1.1rem; letter-spacing: 0.15em; font-weight: 600;">Seria:</span>
                <span class="fw-bold" style="font-family: 'Courier New', monospace; font-size: 2.25rem; line-height: 1; min-width: 2ch; display: inline-block; text-align: right;">@Model.seria.ToString("00")</span>
            </div>

        </div>
    </div>
  
    <div class="row">
        <div class="col-md-6 mx-auto">
            <div class="card border rounded-4" style="border-color: #212529 !important; border-width: 2px;">
                <div class="card-body p-5 text-center">
                    
                   

                    <div class="d-flex align-items-center justify-content-center text-dark fw-bold mb-5" style="font-size: 3rem; gap: 15px;">
                        @if (Model.typ_zadania == "ulamki1")
                        {
                            <div>@Model.liczba1</div>
    
                            <div class="text-primary">&middot;</div>
        
                            <div class="d-inline-flex flex-column align-items-center" style="line-height: 1;">
                                <div class="pb-2">@Model.liczba2</div>
                                <div class="w-100 border-bottom border-3 border-dark"></div>
                                <div class="pt-2">@Model.liczba3</div>
                            </div>

                            <div class="text-muted">=</div>
                            
                        }
                        else if (Model.typ_zadania == "ulamki2")
                        {
                            
                            
                            <div class="d-inline-flex flex-column align-items-center" style="line-height: 1;">
                                <div class="pb-2">@Model.liczba2</div>
                                <div class="w-100 border-bottom border-3 border-dark"></div>
                                <div class="pt-2">@Model.liczba3</div>
                            </div>
                            <div class="text-primary">&middot;</div>
                            
                            <div>@Model.liczba1</div>
                            

                            <div class="text-muted">=</div>
                        }
                        else if (Model.typ_zadania == "pierwiastki")
                        {
                            <div class="d-flex align-items-center">
                                <span class="text-primary display-3 fw-light" style="margin-right: -2px;">&radic;</span>
                                <span class="border-top border-3 border-dark px-2 display-4 fw-bold" style="padding-top: 4px;">
                                    @Model.liczba1
                                </span>
                            </div>
                            <div class="text-muted">=</div>
                        }
                        else if (Model.typ_zadania == "potegi")
                        {
                        <div class="d-flex align-items-start justify-content-center">
                            <span>@Model.liczba1</span>
                            <sup class="text-primary fw-bold" style="font-size: 1.8rem; margin-left: 2px; margin-top: -5px;">
                                @Model.liczba2
                            </sup>
                        </div>
    
                        <div class="text-muted ms-2">=</div>
                        }
                        else if (Model.typ_zadania == "mnozenie_calkowite")
                        {
                            string liczba1Wyswietlana = Model.liczba_calkowita1 < 0 ? $"({Model.liczba_calkowita1})" : Model.liczba_calkowita1.ToString();
                            string liczba2Wyswietlana = Model.liczba_calkowita2 < 0 ? $"({Model.liczba_calkowita2})" : Model.liczba_calkowita2.ToString();
                            <p> @liczba1Wyswietlana × @liczba2Wyswietlana</p>
                        }
                        else if (Model.typ_zadania == "dodawanie_mnozenie_calkowite")
                        {
                            string liczba1Wyswietlana = Model.liczba_calkowita1 < 0 ? $"({Model.liczba_calkowita1})" : Model.liczba_calkowita1.ToString();
                            string liczba2Wyswietlana = Model.liczba_calkowita2 < 0 ? $"({Model.liczba_calkowita2})" : Model.liczba_calkowita2.ToString();
                            string liczba3Wyswietlana = Model.liczba_calkowita3 < 0 ? $"({Model.liczba_calkowita3})" : Model.liczba_calkowita3.ToString();

                            string wzor = "";

                            if (Model.gdzie_znak == 1)
                            {
                                wzor = $"{liczba1Wyswietlana} - {liczba2Wyswietlana} × {liczba3Wyswietlana}";
                            }
                            else if (Model.gdzie_znak == 2)
                            {
                                wzor = $"{liczba1Wyswietlana} + {liczba2Wyswietlana} × {liczba3Wyswietlana}";
                            }
                            else if (Model.gdzie_znak == 3)
                            {
                                wzor = $"{liczba1Wyswietlana} × {liczba2Wyswietlana} + {liczba3Wyswietlana}";
                            }
                            else if (Model.gdzie_znak == 4)
                            {
                                wzor = $"{liczba1Wyswietlana} × {liczba2Wyswietlana} - {liczba3Wyswietlana}";
                            }

                            <p>@wzor</p>
                        }

                    </div>

                    <form method="post">
                        <input type="hidden" asp-for="liczba1" />
                        <input type="hidden" asp-for="liczba2" />
                        <input type="hidden" asp-for="liczba3" />
                        <input type="hidden" asp-for="liczba4" />
                        <input type="hidden" asp-for="seria" />
                        <input type="hidden" asp-for="typ_zadania" />
                        <input type="hidden" asp-for="liczba_calkowita1" />
                        <input type="hidden" asp-for="liczba_calkowita2" />
                        <input type="hidden" asp-for="liczba_calkowita3" />
                        <input type="hidden" asp-for="gdzie_znak" />

                        <div class="mb-4">
                            <label for="odpowiedz_uzytkownika" class="form-label text-muted">Wpisz swój wynik poniżej:</label>
                            <input type="text" asp-for="odpowiedz_uzytkownika" class="form-control form-control-lg text-center fw-bold border-2" placeholder="Twój wynik" style="font-size: 1.5rem;" autocomplete="off" autofocus>
                            </div>
    
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary btn-lg rounded-3 fw-bold py-3 shadow">Sprawdź odpowiedź</button>
                            </div>
                        </form>
                        @if (!string.IsNullOrEmpty(Model.komunikat_zwrotny))
                        {
                            <div class="alert alert-info text-center mt-4 rounded-3 shadow-sm" role="alert">
                                @Model.komunikat_zwrotny
                            </div>
                        }

                </div>
            </div>
            
           
        </div>
    </div>
</div>